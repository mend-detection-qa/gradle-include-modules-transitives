# Mend Unified Agent config reproducing TKA-10120
# Scans only the payments-data-consumer module via includeModules

apiKey=YOUR_API_KEY_HERE
wss.url=https://saas.whitesourcesoftware.com/agent
productName=TKA-10120-reproducer
projectName=gradle-include-modules-transitives

# The critical config combination from the customer ticket:
gradle.includeModules=payments-data-consumer
gradle.aggregateModules=true
gradle.resolveDependencies=true
resolveAllDependencies=false

# Scan the repo root
fileSystemScan=false

# Verbose logging for investigation
log.level=debug

# -----------------------------------------------------------------------
